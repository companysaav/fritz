# Copy to .env.local and fill in from your Supabase project:
# Dashboard -> Project Settings -> API Keys

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# Publishable key (sb_publishable_...) — safe for the browser, governed by RLS.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Secret / service-role key — SERVER ONLY. Bypasses RLS. Never expose to the
# browser or commit the real value. Used by src/lib/supabase/admin.ts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
